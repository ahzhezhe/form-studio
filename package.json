  "files": [
    ".github/FUNDING.yml",
    "dist/**/*"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "lint": "eslint src/*.ts src/**/*.ts test/**/*.ts",
    "test": "jest",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
