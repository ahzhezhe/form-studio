    "eslint": "8.57.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-security": "1.7.1",
    "jest": "30.3.0",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "typedoc": "0.28.19",
    "typescript": "6.0.3"
